# Rust
/target/

# Python (modules/ still uses Python)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/

# Virtual environments
.venv/
venv/
ENV/
env/

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Type checking
.mypy_cache/
.pyright/

# Ruff
.ruff_cache/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Secrets / config — never commit API keys
.env
.env.*
!.env.example

# Don't commit user memory databases
*.db
*.db-shm
*.db-wal

# Project-local memory directory
.engram/

# NOTE: ~/.engram/ (user-global memory dir) cannot be gitignored from here;
# add it to your global ~/.gitignore_global if desired.

# fastembed local model cache (~90 MB binary weights)
.fastembed_cache/
*/.fastembed_cache/
.engram/sync.key
